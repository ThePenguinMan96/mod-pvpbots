# If enabled, pvpbots will not log in until at least one real (non-bot) player
# is online, and will log out after all real players have been offline for
# DisabledWithoutRealPlayerLogoutDelay seconds.
# This saves server resources on idle servers.
# Default: 0 (bots are always online)
PvpBots.DisabledWithoutRealPlayer = 0

# Seconds to wait after a real player logs in before pvpbots log in.
# Only used when DisabledWithoutRealPlayer = 1.
# Default: 30
PvpBots.DisabledWithoutRealPlayerLoginDelay = 30

# Seconds to wait after the last real player logs out before pvpbots log out.
# Only used when DisabledWithoutRealPlayer = 1.
# Default: 300
PvpBots.DisabledWithoutRealPlayerLogoutDelay = 300

# Delete all pvpbot accounts, characters, and registry data.
# To perform a full reset:
#   1. Set to 1 and restart — deletion runs, then server stops
#   2. Set back to 0 and restart — bots are recreated fresh
# WARNING: This permanently deletes all pvpbot characters.
# Default: 0
PvpBots.DeletePvpBotAccounts = 0

# Enable verbose debug logging for this module.
# Default: 0
PvpBots.Debug = 0

################################################################################
# Logging
#
# AzerothCore only reads Appender/Logger entries from worldserver.conf —
# entries in module conf files are ignored by the log system.
#
# To get a dedicated PvpBots.log alongside console output, add these two lines
# to your worldserver.conf (near the other Appender/Logger definitions):
#
#   Appender.PvpBots=2,5,0,PvpBots.log,w
#   Logger.pvpbots=5,Console PvpBots
#
# Appender format: Type,Level,Flags,Filename,Mode
#   Type  — 2 = File
#   Level — 5 = Debug (captures Info, Warn, Error, Fatal too)
#   Flags — 0 = None
#   Mode  — w = overwrite each restart (use 'a' to append instead)
#
# Logger format: Level,AppenderList
#   Level        — 5 = Debug
#   AppenderList — space-separated appender names defined above
################################################################################
