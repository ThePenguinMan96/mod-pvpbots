################################################################################
# mod-pvpbots configuration
#
# Creates dedicated PvP-only bots separate from the general randombot pool.
# Requires mod-playerbots and AiPlayerbot.Enabled = 1.
#
# PvP bots run independently of AiPlayerbot.MinRandomBots / MaxRandomBots.
# AiPlayerbot.RandomBotAutologin does NOT need to be enabled.
################################################################################

[worldserver]

# Enable or disable mod-pvpbots entirely.
# Default: 1
PvpBots.Enable = 1

# Account name prefix for pvpbot accounts (e.g. pvpbot0, pvpbot1, ...).
# WARNING: Do not change this after bots have been created — orphaned accounts result.
# Default: "pvpbot"
PvpBots.AccountPrefix = "pvpbot"

# Total number of PvP bots to create and maintain.
# Default: 50
PvpBots.TotalCount = 50

# Faction distribution mode.
#   0 — All Horde
#   1 — All Alliance
#   2 — Alternating 50/50 (recommended)
#   3 — Custom ratio via HordePercent / AlliancePercent
# Default: 2
PvpBots.FactionMode = 2

# Only used when FactionMode = 3. Must sum to 100.
PvpBots.HordePercent    = 50
PvpBots.AlliancePercent = 50

# Level distribution across ten brackets.
# Each bot is assigned a random level within its bracket's range.
# Values are percentages of PvpBots.TotalCount — must sum to exactly 100.
# Set a bracket to 0 to exclude that level range entirely.
# Default: 10% each (evenly spread across all brackets)
PvpBots.Level10to19Percent = 10
PvpBots.Level20to29Percent = 10
PvpBots.Level30to39Percent = 10
PvpBots.Level40to49Percent = 10
PvpBots.Level50to59Percent = 10
PvpBots.Level60Percent     = 10
PvpBots.Level61to69Percent = 10
PvpBots.Level70Percent     = 10
PvpBots.Level71to79Percent = 10
PvpBots.Level80Percent     = 10

###############################################################################
# Gear
###############################################################################

# Maximum item quality that PlayerbotFactory will equip on pvpbots.
# 1 = Normal  2 = Uncommon  3 = Rare  4 = Epic  5 = Legendary
# Default: 4 (Epic)
PvpBots.GearQualityLimit = 4

# Maximum item level (not gearscore) for pvpbot equipment. 0 = no limit.
# Useful for keeping lower-bracket bots from getting endgame items.
# WotLK iLvL reference: Naxx = 200-213, Ulduar = 226-245, ToC = 245-258, ICC = 251-284
# Default: 0 (no limit)
PvpBots.GearScoreLimit = 0

# Set to 1 to prefer gear with resilience rating over otherwise equal PvE items.
# Set to 0 if you want bots to use pure StatsWeightCalculator scoring with no
# preference for resilience.
# Default: 1
PvpBots.PreferResilienceGear = 1

# Set to 1 to place the CC-break trinket ("Removes all movement impairing effects
# and all effects which cause loss of control of your character") in trinket slot 1.
# This applies to all bots regardless of level. Bots that cannot find a CC-break
# trinket for their level will use the best PvE trinket instead.
# Default: 1
PvpBots.EnableCcBreakTrinket = 1

# Set to 1 to equip the faction heirloom CC-break trinket (Inherited Insignia of
# the Alliance / Horde, items 44098 / 44097) in trinket slot 1 when no
# level-appropriate CC-break trinket is found in the cache.
# These heirlooms scale with the bot's level and have no level requirement.
# Note: if the server enforces account-bound restrictions on heirlooms, the slot
# will simply remain empty rather than cause an error.
# Default: 1
PvpBots.EnableHeirloomCcTrinket = 1

###############################################################################
# PvP Specs
#
# Each class has up to 3 PvP specs numbered 0, 1, 2 (0-indexed, matching the
# three talent trees: tree 0, tree 1, tree 2).
# One is chosen at random when a bot logs in.
# The highest-level link that does not exceed the bot's level is used.
#
# PvpBots.SpecName.<class>.<tab>         = display name
# PvpBots.SpecLink.<class>.<tab>.<level> = wowhead-style talent link
# PvpBots.SpecGlyph.<class>.<tab>        = glyph item IDs, 6 entries in slot order:
#                                          major0, major1, minor0, major2, minor1, minor2
#
# Specs are contiguous — a missing SpecName.X.0 means no specs for class X.
# Tab numbering mirrors the three talent trees (0 = first tree, 1 = second, 2 = third).
###############################################################################

####################################################################################################
# WARRIOR (class 1)
# Tab 0 = Arms  |  Tab 1 = Fury  |  Tab 2 = Protection
